generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  role      String   @default("client")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contractorProfile ContractorProfile?
  clientProfile    ClientProfile?
  reviews          Review[]
}

model ContractorProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  companyName       String
  ncaNumber         String?
  ncaCategory       String?
  businessPin       String?
  physicalAddress   String?
  county            String?
  description       String?
  website           String?
  isVerified        Boolean  @default(false)
  isPremium         Boolean  @default(false)
  verificationDate  DateTime?
  premiumExpiry     DateTime?
  compositeScore    Int      @default(0)
  onTimeScore       Int      @default(0)
  qualityScore      Int      @default(0)
  subPayScore       Int      @default(0)
  responsiveScore   Int      @default(0)
  disputeScore      Int      @default(0)
  totalProjectValue Int      @default(0)
  crbStatus         String   @default("Not Checked")
  itaxCompliant     Boolean  @default(false)
  isBlacklisted     Boolean  @default(false)
  blacklistReason   String?
  agpoNumber        String?
  agpoCategory      String?
  agpoVerified      Boolean  @default(false)
  agpoExpiry        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user           User                @relation(fields: [userId], references: [id])
  projects       Project[]
  documents      ContractorDocument[]
  receivedReviews Review[]
  disputes       Dispute[]
  lpos           LocalPurchaseOrder[]
}

model ClientProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String?
  clientType     String   @default("individual")
  compositeScore Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  projects  Project[]
}

model Project {
  id            String    @id @default(cuid())
  contractorId  String
  clientId      String?
  title         String
  projectType   String
  contractValue Int
  startDate     DateTime?
  endDate       DateTime?
  actualEnd     DateTime?
  status        String    @default("active")
  county        String?
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contractor ContractorProfile @relation(fields: [contractorId], references: [id])
  client      ClientProfile?    @relation(fields: [clientId], references: [id])
  reviews     Review[]
  milestones  Milestone[]
  lpos        LocalPurchaseOrder[]
}

model Review {
  id               String   @id @default(cuid())
  projectId        String
  contractorId     String
  reviewerId       String
  reviewerName     String
  onTimeRating     Int
  qualityRating    Int
  subPayRating     Int
  responsiveRating Int
  overallComment   String?
  status           String   @default("pending")
  contractorReply  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project    Project           @relation(fields: [projectId], references: [id])
  contractor ContractorProfile @relation(fields: [contractorId], references: [id])
  reviewer   User              @relation(fields: [reviewerId], references: [id])
}

model Dispute {
  id              String   @id @default(cuid())
  contractorId    String
  projectId       String?
  clientId        String?
  title           String
  description     String
  status          String   @default("open")
  resolution      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contractor ContractorProfile @relation(fields: [contractorId], references: [id])
}

model ContractorDocument {
  id           String    @id @default(cuid())
  contractorId String
  docType      String
  docName      String
  status       String    @default("pending")
  uploadDate   DateTime  @default(now())
  expiryDate   DateTime?

  contractor ContractorProfile @relation(fields: [contractorId], references: [id])
}

model Milestone {
  id            String    @id @default(cuid())
  projectId     String
  title         String
  description   String?
  percentage    Int       @default(0)
  dueDate       DateTime?
  completedDate DateTime?
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String?
  amount    Int
  currency  String   @default("KES")
  type      String
  status    String   @default("pending")
  mpesaRef  String?
  createdAt DateTime @default(now())
}

model LocalPurchaseOrder {
  id             String   @id @default(cuid())
  contractorId   String
  lpoNumber      String
  issuingOrg     String
  scopeOfWorks   String?
  lpoValue       Int
  issuedDate     DateTime?
  validUntil     DateTime?
  projectId      String?
  status         String   @default("issued")
  utilizationPct  Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contractor ContractorProfile @relation(fields: [contractorId], references: [id])
  project    Project?           @relation(fields: [projectId], references: [id])
}